    "@react-navigation/native-stack": "^7.14.10",
    "axios": "^1.14.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-font": "^13.0.4",
    "expo-notifications": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "i18next": "^24.2.3",
    "metro": "^0.81.0",
    "metro-config": "^0.81.0",
    "metro-resolver": "^0.81.0",
    "metro-runtime": "^0.81.0",
    "react": "18.3.1",
    "react-i18next": "^15.7.4",
    "react-native": "^0.76.9",
    "react-native-chart-kit": "^6.12.0",
