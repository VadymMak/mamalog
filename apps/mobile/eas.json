{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20",
      "pnpm": "9.15.0",
      "installCommand": "pnpm install --frozen-lockfile",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "node": "20",
      "pnpm": "9.15.0",
      "installCommand": "pnpm install --frozen-lockfile",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mamalog-web.vercel.app"
      }
    },
    "production": {
      "node": "20",
      "pnpm": "9.15.0",
      "installCommand": "pnpm install --frozen-lockfile",
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {}
  }
}
